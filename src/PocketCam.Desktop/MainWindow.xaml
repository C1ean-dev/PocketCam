<Window x:Class="PocketCam.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PocketCam" Width="1120" Height="720" MinWidth="880" MinHeight="600"
        Background="{StaticResource BackgroundBrush}" WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.1*" />
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel>
                <TextBlock Text="POCKETCAM" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="12" />
                <TextBlock Text="Webcam conectada, sem complicação." FontSize="25" FontWeight="SemiBold" Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Row="2" Background="#030B0D" CornerRadius="16" ClipToBounds="True">
                <Grid>
                    <Image Source="{Binding PreviewFrame}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding EmptyPreviewVisibility}">
                        <TextBlock Text="Aguardando o Android" HorizontalAlignment="Center" FontSize="21" FontWeight="SemiBold" />
                        <TextBlock Text="Abra o PocketCam no celular; ele aparecerá automaticamente."
                                   Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
                    </StackPanel>
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14" Padding="10,6"
                            CornerRadius="12" Background="#CC102B2F">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,7,0" />
                            <TextBlock Text="{Binding ActiveTransportLabel}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding FramesPerSecond, StringFormat={}{0:F1} FPS}" Margin="0,0,18,0" />
                    <TextBlock Text="{Binding LatencyText}" />
                </StackPanel>
            </Grid>
        </Grid>

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Conexões" FontSize="17" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding Connections}" Margin="0,10,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Margin="0,0,0,7" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding TransportLabel}" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{Binding StateBrush}" CornerRadius="9" Padding="8,3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StateLabel}" FontSize="11" Foreground="#071A1D" FontWeight="Bold" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Vídeo" FontSize="17" FontWeight="SemiBold" />
                <TextBlock Text="Resolução" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,5" />
                <ComboBox ItemsSource="{Binding ResolutionOptions}" SelectedItem="{Binding SelectedResolution}" />
                <TextBlock Text="{Binding SelectedFps, StringFormat=FPS: {0}}" Foreground="{StaticResource MutedBrush}" Margin="0,14,0,3" />
                <Slider Minimum="5" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding SelectedFps}" />
                <TextBlock Text="{Binding JpegQuality, StringFormat=Qualidade: {0}%}" Foreground="{StaticResource MutedBrush}" Margin="0,14,0,3" />
                <Slider Minimum="40" Maximum="95" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding JpegQuality}" />
                <ComboBox Margin="0,14,0,0" ItemsSource="{Binding LensOptions}" SelectedItem="{Binding SelectedLens}" />
                <Button Content="Aplicar no celular" Command="{Binding ApplySettingsCommand}" Margin="0,12,0,0"
                        Background="{StaticResource AccentBrush}" Foreground="#041416" />

                <TextBlock Text="Câmera virtual" FontSize="17" FontWeight="SemiBold" Margin="0,24,0,8" />
                <TextBlock Text="{Binding VirtualCameraText}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                <Button Content="Instalar / reparar câmera" Command="{Binding InstallVirtualCameraCommand}" Margin="0,12,0,0" />

                <TextBlock Text="Atualizações" FontSize="17" FontWeight="SemiBold" Margin="0,24,0,8" />
                <TextBlock Text="{Binding UpdateStatusText}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                <Button Content="Verificar atualizações" Command="{Binding CheckForUpdatesCommand}" Margin="0,12,0,0" />

                <TextBlock Text="USB usa ADB e assume automaticamente quando o cabo é conectado."
                           Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,22,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
